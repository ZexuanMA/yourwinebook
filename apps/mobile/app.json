{
  "expo": {
    "name": "Your Wine Book",
    "slug": "your-wine-book",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "yourwinebook",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourwinebook.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your Wine Book needs your location to find nearby wine stores.",
        "NSPhotoLibraryUsageDescription": "Your Wine Book needs access to your photos to add images to posts.",
        "NSCameraUsageDescription": "Your Wine Book needs access to your camera to take photos for posts."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF8F5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.yourwinebook.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@sentry/react-native",
      "expo-localization",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Your Wine Book needs your location to find nearby wine stores.",
          "locationWhenInUsePermission": "Your Wine Book needs your location to find nearby wine stores."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Your Wine Book needs access to your photos to add images to posts.",
          "cameraPermission": "Your Wine Book needs access to your camera to take photos for posts."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "a573b88a-c637-4613-a7ab-3f82b8d5d7e2"
      },
      "router": {}
    },
    "updates": {
      "url": "https://u.expo.dev/a573b88a-c637-4613-a7ab-3f82b8d5d7e2"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "zexuan"
  }
}
