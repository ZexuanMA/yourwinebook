{
  "name": "your-wine-book",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "lint": "pnpm --filter web lint",
    "deploy": "pnpm --filter web build && pm2 restart wine-prod",
    "start": "echo 'Use pm2 restart wine-prod instead' && exit 1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "@swc/core",
      "@parcel/watcher",
      "sharp",
      "unrs-resolver"
    ]
  }
}
